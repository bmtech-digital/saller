# ===========================================
# Backend Production Environment Variables
# For Google Cloud Run deployment
# ===========================================

# Server Configuration
PORT=3001
NODE_ENV=production

# Supabase Configuration (Required)
# These should be stored in Google Secret Manager
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Frontend URL for CORS (Required)
# This will be your Cloud Run frontend URL
FRONTEND_URL=https://proposal-frontend-xxxxx-xx.a.run.app

# Email Configuration (Optional - for sending proposals via email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# WhatsApp Business API (Optional)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0/YOUR_PHONE_ID/messages
WHATSAPP_API_TOKEN=your-whatsapp-api-token

# SMS API (Optional)
SMS_API_URL=https://api.sms-provider.com/send
SMS_API_KEY=your-sms-api-key
